# =====================================================================
# OJEX — Environment Variables Template
# Copy this file to `.env` for local dev, and set each variable in
# Vercel → Project → Settings → Environment Variables for deployment.
# =====================================================================

# ---------------------------------------------------------------------
# Public (client-side) — MUST be prefixed with VITE_ so Vite inlines
# them into the browser bundle at BUILD time. Set these in Vercel
# BEFORE the build runs (all environments: Production, Preview, Dev).
# ---------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Canonical site URL — used for absolute links in emails, sitemap, OG tags.
VITE_SITE_URL=https://www.ojexoilandgasservices.com

# ---------------------------------------------------------------------
# Server-only — used by TanStack server functions and API routes.
# NEVER prefix with VITE_. NEVER commit real values to Git.
# Set these in Vercel Environment Variables (Production + Preview).
# ---------------------------------------------------------------------

# Supabase server-side
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key   # admin ops only — keep secret

# Lovable AI Gateway (server → AI models, connectors)
LOVABLE_API_KEY=your-lovable-api-key

# Site URL (server copy — used in emails/webhooks)
SITE_URL=https://www.ojexoilandgasservices.com

# ---------------------------------------------------------------------
# Optional — only set if you use these features
# ---------------------------------------------------------------------

# Gmail connector (auto-populated when the Gmail connector is linked)
# GOOGLE_MAIL_API_KEY=

# Google Search Console verification token (already embedded in <head>)
# GSC_VERIFICATION_TOKEN=

# =====================================================================
# Deployment checklist (Vercel)
# 1. Import the GitHub repo into Vercel.
# 2. Framework preset: "Other" (TanStack Start / Vite).
# 3. Build command:   bun run build
# 4. Output dir:      .output  (TanStack Start default)
# 5. Install command: bun install
# 6. Add every variable above under Settings → Environment Variables.
#    - VITE_* → available at build time (client bundle)
#    - Others → available at runtime (server functions)
# 7. Redeploy after any env var change so the new values take effect.
# =====================================================================
